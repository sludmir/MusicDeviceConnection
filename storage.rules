rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // ---- Helpers ----
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    // Set media is stored as "<uid>_<timestamp>_<name>" (no uid path segment),
    // so the owner is derived from the filename prefix.
    function isNamePrefixedByUid(fileName) {
      return isSignedIn() && fileName.matches(request.auth.uid + '_.*');
    }

    function isValidImage() {
      return request.resource.contentType.matches('image/.*')
        && request.resource.size < 5 * 1024 * 1024; // 5MB max
    }

    function isValidModel() {
      return request.resource.contentType.matches('model/.*|application/octet-stream|image/.*')
        && request.resource.size < 50 * 1024 * 1024; // 50MB max
    }

    function isValidVideo() {
      return request.resource.contentType.matches('video/.*')
        && request.resource.size < 10 * 1024 * 1024 * 1024; // 10GB max
    }

    function isValidAudio() {
      return request.resource.contentType.matches('audio/.*|application/octet-stream')
        && request.resource.size < 1024 * 1024 * 1024; // 1GB max (covers full-set lossless audio)
    }

    // ---- Catalog assets: world-readable, admin-managed ----
    // (Uploads come only from the /admin/products screens. Locking writes+deletes
    //  to the admin claim stops any signed-in user overwriting/deleting the shared
    //  3D catalog — previously delete was allowed to anyone signed in.)
    match /models/{allPaths=**} {
      allow read: if true;                            // public read (builder needs it)
      allow create, update: if isAdmin() && isValidModel();
      allow delete: if isAdmin();
    }

    match /textures/{allPaths=**} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidImage();
      allow delete: if isAdmin();
    }

    match /images/{allPaths=**} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidImage();
      allow delete: if isAdmin();
    }

    // Device-specific 3D models / images (admin-managed; no user upload path)
    match /devices/{deviceId}/images/{imageId} {
      allow read: if isSignedIn();
      allow create, update: if isAdmin() && isValidImage();
      allow delete: if isAdmin();
    }
    match /devices/{deviceId}/models/{allPaths=**} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidModel();
      allow delete: if isAdmin();
    }

    // ---- User content ----
    // Profile images — owner only
    match /users/{userId}/profile/{imageId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isOwner(userId) && isValidImage();
    }

    // Setup screenshots — path carries no uid, so kept at signed-in write
    // (worst case is a cosmetic preview overwrite; low risk).
    match /setups/{setupId}/screenshots/{imageId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isValidImage();
    }

    // Live-set media: audio tracks (sets/audio/**) + thumbnails (sets/thumbnails/**),
    // plus legacy video. Read stays public because <video>/<audio> download URLs are
    // fetched by the browser without a Firebase auth token. Writes + deletes are
    // scoped to the owner via the "<uid>_..." filename prefix (was: any signed-in
    // user could overwrite/delete anyone's set media).
    match /sets/{allPaths=**} {
      allow read: if true;
    }
    match /sets/{folder}/{fileName} {
      allow create, update: if isNamePrefixedByUid(fileName)
        && (isValidVideo() || isValidAudio() || isValidImage());
      allow delete: if isNamePrefixedByUid(fileName);
    }

    // Clips — short video now streams from Bunny; this Storage path is unused.
    // Keep authenticated read; deletes locked to admin (was: any signed-in user).
    match /clips/{allPaths=**} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && isValidVideo();
      allow delete: if isAdmin();
    }
  }
}
