# Firebase Configuration - Replace with your own values
REACT_APP_FIREBASE_API_KEY=your-api-key
REACT_APP_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=your-project-id
REACT_APP_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
REACT_APP_FIREBASE_APP_ID=your-app-id
REACT_APP_FIREBASE_MEASUREMENT_ID=your-measurement-id

# Security Settings
REACT_APP_AUTH_DOMAIN=connectmyset.com
REACT_APP_SECURE_ORIGIN=true

# Amazon Associates tracking tag (set after Associates signup, then rebuild)
REACT_APP_AMAZON_ASSOC_TAG=

# zZounds in-house affiliate ID (path-based a--3998299 links; creator tracking via sid--)
REACT_APP_ZZOUNDS_AFFILIATE_ID=3998299

