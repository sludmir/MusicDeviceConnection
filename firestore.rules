rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Verified-creator flag on users/{uid}, granted only by the admin.
    // Gates live-set posting (sets + clips); admins count as creators.
    function isCreator() {
      return request.auth.token.admin == true
        || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('creator', false) == true;
    }

    function isValidSetup() {
      return request.resource.data.keys().hasAll(['name', 'ownerId', 'createdAt', 'devices'])
        && request.resource.data.name is string
        && request.resource.data.ownerId is string
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.createdAt is timestamp
        && request.resource.data.devices is list;
    }

    function isValidDevice() {
      return request.resource.data.keys().hasAll(['name', 'type', 'ownerId'])
        && request.resource.data.name is string
        && request.resource.data.type is string
        && request.resource.data.ownerId is string
        && request.resource.data.ownerId == request.auth.uid;
    }

    function isValidProduct() {
      return request.resource.data.keys().hasAll(['name', 'type', 'ownerId'])
        && request.resource.data.name is string
        && request.resource.data.type is string
        && request.resource.data.ownerId is string
        && request.resource.data.ownerId == request.auth.uid
        && (!('modelPath' in request.resource.data) || request.resource.data.modelPath is string);
    }

    // Products
    match /products/{productId} {
      allow read: if true;
      // Catalog is shared + world-readable, so only admins may add products.
      // (The UI already gates creation on the admin claim; this closes the
      // rule-level gap that let any signed-in user inject catalog entries /
      // affiliate URLs by calling Firestore directly.)
      allow create: if isSignedIn() && request.auth.token.admin == true && isValidProduct();
      allow update: if isSignedIn() && (resource.data.ownerId == request.auth.uid || request.auth.token.admin == true);
      allow delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || request.auth.token.admin == true);
    }

    // Affiliate click ledger: clients append, only admin reads
    match /affiliateClicks/{clickId} {
      allow create: if isSignedIn()
        && request.resource.data.clickerUid == request.auth.uid
        && request.resource.data.productName is string
        && request.resource.data.source in ['hover-menu', 'mini-profile'];
      allow read, update, delete: if isSignedIn() && request.auth.token.admin == true;
    }

    // Ghost-spot layouts (admin-editable builder placement templates)
    match /ghostSpotLayouts/{layoutId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.token.admin == true;
    }

    // User profiles. Owners manage their own doc but can never grant
    // themselves the `creator` flag — only the admin can flip it.
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isOwner(userId)
        && !('creator' in request.resource.data);
      allow update: if isSignedIn() && (
        (isOwner(userId)
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['creator'])) ||
        (request.auth.token.admin == true
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['creator']))
      );
      allow delete: if isSignedIn() && isOwner(userId);
      // Followers: anyone can add/remove themselves as follower of userId
      match /followers/{followerId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && request.auth.uid == followerId;
        allow delete: if isSignedIn() && request.auth.uid == followerId;
      }
      // Notifications: only owner can read/update/delete; creator can create (fromUserId == auth.uid)
      match /notifications/{notificationId} {
        allow read, update, delete: if isSignedIn() && request.auth.uid == userId;
        allow create: if isSignedIn() && request.resource.data.fromUserId == request.auth.uid;
      }
    }

    // Setups (saved rig configs)
    match /setups/{setupId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidSetup();
      allow update, delete: if isSignedIn() && isOwner(resource.data.ownerId);
    }

    // Devices
    match /devices/{deviceId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidDevice();
      allow update, delete: if isSignedIn() && isOwner(resource.data.ownerId);
    }

    // Connections — retired collection. No code reads or writes it anymore;
    // it was previously writable/deletable by ANY signed-in user. Deny all.
    match /connections/{connectionId} {
      allow read, write: if false;
    }

    function isClipSocialBump() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'likedBy']) ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['commentCount']) &&
         request.resource.data.commentCount == resource.data.get('commentCount', 0) + 1);
    }

    function isSetSocialBump() {
      return (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views']) &&
              request.resource.data.views == resource.data.get('views', 0) + 1) ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['commentCount']) &&
         request.resource.data.commentCount == resource.data.get('commentCount', 0) + 1);
    }

    function isValidComment() {
      // serverTimestamp() is a write sentinel during rule evaluation — do not
      // require `createdAt is timestamp` or creates will always be denied.
      return request.resource.data.keys().hasAll(['authorId', 'authorName', 'text', 'createdAt']) &&
        request.resource.data.authorId == request.auth.uid &&
        request.resource.data.authorName is string &&
        request.resource.data.text is string &&
        request.resource.data.text.size() > 0 &&
        request.resource.data.text.size() <= 500;
    }

    function isCommentLikeBump() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'likedBy']);
    }

    function conversationExists(conversationId) {
      return exists(/databases/$(database)/documents/conversations/$(conversationId));
    }

    function isParticipantList(participantIds) {
      return participantIds is list
        && participantIds.hasAny([request.auth.uid]);
    }

    function isConversationParticipant(conversationId) {
      return conversationExists(conversationId)
        && isParticipantList(get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds);
    }

    function isConversationParticipantAfter(conversationId) {
      return isParticipantList(getAfter(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds);
    }

    function isValidConversationWrite() {
      return request.resource.data.participantIds is list
        && request.resource.data.participantIds.size() == 2
        && isParticipantList(request.resource.data.participantIds);
    }

    function isValidMessageCreate(conversationId) {
      return request.resource.data.senderId == request.auth.uid
        && request.resource.data.type in ['text', 'clip', 'liveSet']
        && (isConversationParticipant(conversationId) || isConversationParticipantAfter(conversationId))
        && (
          request.resource.data.type == 'text'
          || request.resource.data.type == 'clip'
          || request.resource.data.type == 'liveSet'
        );
    }

    // Clips (short-form feed videos) — posting requires a creator account
    match /clips/{clipId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.creatorId == request.auth.uid && isCreator();
      allow update: if isSignedIn() && (
        resource.data.creatorId == request.auth.uid ||
        isClipSocialBump()
      );
      allow delete: if isSignedIn() && resource.data.creatorId == request.auth.uid;

      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && isValidComment();
        allow update: if isSignedIn() && (
          resource.data.authorId == request.auth.uid ||
          isCommentLikeBump()
        );
        allow delete: if isSignedIn() && resource.data.authorId == request.auth.uid;
      }
    }

    // Sets (full live set references) — posting requires a creator account
    match /sets/{setId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.creatorId == request.auth.uid && isCreator();
      allow update: if isSignedIn() && (
        resource.data.creatorId == request.auth.uid ||
        isSetSocialBump()
      );
      allow delete: if isSignedIn() && resource.data.creatorId == request.auth.uid;

      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && isValidComment();
        allow update: if isSignedIn() && (
          resource.data.authorId == request.auth.uid ||
          isCommentLikeBump()
        );
        allow delete: if isSignedIn() && resource.data.authorId == request.auth.uid;
      }
    }

    // Direct messages between two users
    match /conversations/{conversationId} {
      allow read: if isSignedIn() && isParticipantList(resource.data.participantIds);
      allow create: if isSignedIn() && isValidConversationWrite();
      allow update: if isSignedIn() && isParticipantList(resource.data.participantIds);

      match /messages/{messageId} {
        allow read: if isSignedIn() && isConversationParticipant(conversationId);
        allow create: if isSignedIn() && isValidMessageCreate(conversationId);
        allow update: if isSignedIn() && isConversationParticipant(conversationId);
      }
    }
  }
}
